{
  "permissions": {
    "allow": [
      "mcp__Claude_Code_Remote__send_later",
      "mcp__Claude_Code_Remote__delete_trigger"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check.sh"
          }
        ]
      }
    ]
  }
}
